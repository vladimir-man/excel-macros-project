# Игнорировать временные файлы Excel
*.xl*
~$*.xls*
*.tmp

# Игнорировать резервные файлы
*.bak
*.old

# Игнорировать системные файлы
Thumbs.db
.DS_Store

# Игнорировать файлы из VS Code
.vscode/
*.code-workspace

# Игнорировать бинарные файлы и логи
*.log
*.exe
*.dll

# Игнорировать тестовые Excel-файлы (если не нужны в репозитории)
tests/*.xlsm